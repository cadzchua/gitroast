# Required: Your LLM API key (e.g., OpenAI, Groq, etc.)
GITROAST_API_KEY=sk-your-api-key-here

# Optional: Model to use (defaults to gpt-4o-mini)
GITROAST_MODEL=gpt-4o-mini

# Optional: API base URL for OpenAI-compatible providers (defaults to https://api.openai.com/v1)
# Examples:
#   Groq:   https://api.groq.com/openai/v1
#   Ollama: http://localhost:11434/v1
GITROAST_API_BASE=https://api.openai.com/v1
