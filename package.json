{
  "name": "gitroast",
  "version": "1.1.0",
  "description": "🍖 A CLI tool that analyzes your Git history and roasts your coding habits",
  "main": "dist/index.js",
  "bin": {
    "gitroast": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "roast",
    "cli",
    "humor",
    "developer-tools",
    "git-analytics",
    "commit-analysis"
  ],
  "author": "cadzchua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cadzchua/gitroast.git"
  },
  "homepage": "https://github.com/cadzchua/gitroast#readme",
  "bugs": {
    "url": "https://github.com/cadzchua/gitroast/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "ora": "^5.4.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
